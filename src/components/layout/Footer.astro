---
const year = new Date().getFullYear();
---

<footer class="px-6 pb-8 pt-6 lg:px-10">
  <div class="mx-auto flex w-full max-w-7xl flex-col gap-4 rounded-[2rem] border border-white/10 bg-white/5 px-6 py-6 text-sm text-white/60 shadow-[0_18px_50px_rgba(0,0,0,0.18)] backdrop-blur-xl md:flex-row md:items-center md:justify-between">
    <p>Copyright {year} Giancarlo Arias Dev. Astro, Tailwind y animaciones cuidadas.</p>

    <div class="flex flex-wrap items-center gap-4">
      <a href="/" class="transition hover:text-white">Inicio</a>
      <a href="/#about" class="transition hover:text-white">Sobre mi</a>
      <a href="/contacto" class="transition hover:text-white">Contacto</a>
    </div>
  </div>
</footer>
