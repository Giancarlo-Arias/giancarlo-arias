---
interface Props {
  currentPath?: string;
  deferReveal?: boolean;
}

const { currentPath = "/", deferReveal = false } = Astro.props as Props;

const isActive = (href: string) => {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
};

const links = [
  { href: "/", label: "Inicio" },
  { href: currentPath === "/" ? "#about" : "/#about", label: "Sobre mi", active: currentPath === "/" },
  { href: "/contacto", label: "Contacto" },
];
---

<header
  data-site-nav
  data-nav-reveal={deferReveal ? "deferred" : "ready"}
  class:list={[
    "sticky top-0 z-40 px-4 pt-4 transition-[opacity,transform,filter] duration-500 sm:px-6",
    deferReveal && "pointer-events-none -translate-y-4 opacity-0 blur-md",
  ]}
>
  <nav class="mx-auto flex w-full max-w-7xl items-center justify-between rounded-full border border-white/10 bg-black/25 px-4 py-3 shadow-[0_18px_50px_rgba(0,0,0,0.24)] backdrop-blur-xl sm:px-6">
    <a href="/" class="text-sm font-semibold uppercase tracking-[0.24em] text-white/92">
      Giancarlo Arias
    </a>

    <div class="hidden items-center gap-2 md:flex">
      {links.map((link) => {
        const active = "active" in link ? link.active : isActive(link.href);

        return (
          <a
            href={link.href}
            class:list={[
              "rounded-full px-4 py-2 text-sm transition",
              active
                ? "bg-white/12 text-white"
                : "text-white/62 hover:bg-white/8 hover:text-white",
            ]}
          >
            {link.label}
          </a>
        );
      })}
    </div>

    <a
      href="https://wa.me/50660058595"
      target="_blank"
      rel="noreferrer"
      class="inline-flex items-center gap-2 rounded-full border border-cyan-200/20 bg-gradient-to-r from-[#f4f8fb] via-[#d9ecf8] to-[#bfe2f4] px-4 py-2 text-sm font-medium text-[#081018] shadow-[0_10px_24px_rgba(120,187,224,0.18)] transition duration-300 hover:translate-y-[-1px]"
    >
      WhatsApp
    </a>
  </nav>
</header>
