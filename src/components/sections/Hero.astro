---
import profileImage from "../../assets/profile/Giancarlo.jpeg";
---

<div data-hero-root>
<div
  data-hero-loader
  class="fixed inset-0 z-50 flex min-h-screen items-center justify-center overflow-hidden bg-[#0b0d12]"
>
  <div class="absolute inset-0">
    <div
      data-loader-line
      class="absolute left-1/2 top-0 h-full w-[2px] -translate-x-1/2 bg-gradient-to-b from-transparent via-white/70 to-transparent"
    ></div>
    <div class="absolute left-[-8%] top-[-8%] h-[24rem] w-[24rem] rounded-full bg-cyan-500/12 blur-3xl"></div>
    <div class="absolute right-[-10%] bottom-[-12%] h-[28rem] w-[28rem] rounded-full bg-sky-500/10 blur-3xl"></div>
  </div>

  <div
    class="relative grid w-full max-w-[88rem] grid-cols-[1fr_auto_1fr] items-center px-6 text-[clamp(2.4rem,8vw,7rem)] font-semibold tracking-tight text-white"
  >
    <span data-loader-word="left" class="justify-self-end pr-5 text-right sm:pr-8">Giancarlo</span>
    <span class="w-[2px]"></span>
    <span data-loader-word="right" class="justify-self-start pl-5 text-left sm:pl-8">Arias</span>
  </div>
</div>

<section
  data-hero
  class="mx-auto grid w-full max-w-7xl items-start gap-6 px-6 pt-14 pb-2 lg:grid-cols-[1.05fr_0.95fr] lg:gap-10 lg:pt-[4.5rem] lg:pb-4 2xl:max-w-[110rem] 2xl:px-10"
>
  
  <!-- LEFT CONTENT -->
  <div class="space-y-6 pt-2 lg:space-y-7 lg:pt-2" data-hero-copy>
    <div class="space-y-5">
      <p data-reveal-text class="text-sm uppercase tracking-[0.25em] text-white/45">
        Desarrollo Web e Ingenieria de Sistemas
      </p>

      <h1 data-reveal-text class="max-w-4xl text-5xl font-semibold leading-[0.95] tracking-tight md:text-7xl xl:text-8xl">
        Giancarlo Arias
      </h1>

      <p data-reveal-text class="max-w-2xl text-lg leading-8 text-white/65 md:text-xl">
        Ingeniero de Sistemas apasionado por el ciclo de vida completo del desarrollo de software, enfocado en la creacion de soluciones robustas y escalables.
      </p>
    </div>

    <div class="flex flex-wrap gap-4">
      <a
        href="#experience"
        class="inline-flex items-center gap-2.5 rounded-2xl border border-cyan-300/20 bg-gradient-to-r from-[#f4f8fb] via-[#d9ecf8] to-[#bfe2f4] px-[1.125rem] py-3 font-medium text-[#081018] shadow-[0_12px_40px_rgba(134,196,232,0.28)] transition duration-300 hover:translate-y-[-2px] hover:shadow-[0_18px_55px_rgba(134,196,232,0.34)]"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" aria-hidden="true">
          <path d="M5 12h14" stroke-linecap="round" />
          <path d="m13 6 6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <span>Ver experiencia</span>
      </a>

      <a
        href="https://wa.me/50660058595"
        target="_blank"
        rel="noreferrer"
        class="inline-flex items-center gap-2.5 rounded-2xl border border-cyan-200/24 bg-gradient-to-r from-[#2a556e]/92 via-[#33708f]/88 to-[#4b98b9]/84 px-[1.125rem] py-3 font-medium text-white shadow-[0_14px_36px_rgba(26,68,94,0.24)] backdrop-blur-xl transition duration-300 hover:translate-y-[-2px] hover:border-cyan-100/40 hover:shadow-[0_18px_48px_rgba(40,92,122,0.32)]"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M19.05 4.91A9.82 9.82 0 0 0 12.03 2C6.62 2 2.2 6.4 2.2 11.82c0 1.73.45 3.42 1.3 4.9L2 22l5.44-1.42a9.82 9.82 0 0 0 4.58 1.16h.01c5.41 0 9.82-4.4 9.82-9.82A9.75 9.75 0 0 0 19.05 4.91Zm-7.02 15.18h-.01a8.1 8.1 0 0 1-4.12-1.12l-.3-.18-3.23.84.86-3.15-.2-.32a8.14 8.14 0 0 1-1.25-4.33c0-4.49 3.67-8.15 8.17-8.15 2.18 0 4.22.84 5.76 2.39a8.08 8.08 0 0 1 2.38 5.77c0 4.49-3.67 8.15-8.16 8.15Zm4.47-6.11c-.24-.12-1.42-.7-1.64-.78-.22-.08-.38-.12-.54.12-.16.23-.62.78-.76.94-.14.16-.28.18-.52.06-.24-.12-1.03-.38-1.95-1.21-.72-.64-1.2-1.43-1.34-1.67-.14-.24-.02-.37.1-.49.11-.11.24-.28.36-.42.12-.14.16-.24.24-.4.08-.16.04-.31-.02-.43-.06-.12-.54-1.3-.74-1.78-.2-.48-.4-.41-.54-.42h-.46c-.16 0-.42.06-.64.31-.22.24-.84.82-.84 2 0 1.18.86 2.33.98 2.49.12.16 1.7 2.6 4.12 3.65.58.25 1.03.4 1.38.51.58.18 1.1.16 1.51.1.46-.07 1.42-.58 1.62-1.14.2-.56.2-1.04.14-1.14-.06-.1-.22-.16-.46-.28Z" />
        </svg>
        <span>WhatsApp</span>
      </a>
    </div>
  </div>

  <div
    data-hero-media
    class="relative mx-auto mt-1 w-full max-w-[17.75rem] justify-self-center lg:mt-0 lg:max-w-[19rem] lg:justify-self-end 2xl:max-w-[21rem]"
  >
    <div
      data-hero-media-card
      style="--spotlight-x:50%; --spotlight-y:50%;"
      class="relative min-h-[27rem] overflow-hidden rounded-[2rem] border border-white/10 bg-white/5 p-3 shadow-[0_24px_80px_rgba(0,0,0,0.35)] backdrop-blur-xl lg:min-h-0"
    >
      <div
        data-hero-spotlight
        class="pointer-events-none absolute inset-0 opacity-0"
        style="background: radial-gradient(220px circle at var(--spotlight-x) var(--spotlight-y), rgba(255,255,255,0.22), rgba(140,216,255,0.1) 26%, transparent 62%);"
      ></div>
      <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_28%_18%,rgba(255,255,255,0.28),rgba(255,255,255,0.08)_22%,transparent_48%)] mix-blend-screen"></div>
      <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/12 via-transparent to-white/8"></div>
      <img
        src={profileImage.src}
        width={profileImage.width}
        height={profileImage.height}
        alt="Foto de Giancarlo Arias"
        class="aspect-[4/5] w-full rounded-[1.35rem] object-cover object-center"
        loading="eager"
      />
      <div class="absolute inset-x-3 bottom-3 z-10 rounded-[1.2rem] border border-white/10 bg-black/30 p-3 backdrop-blur-xl">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <p class="text-sm font-medium text-white">@giancarloarias96</p>
            <div class="mt-1 inline-flex items-center gap-2 text-xs text-white/70">
              <span class="h-2 w-2 rounded-full bg-emerald-400"></span>
              <span>Online</span>
            </div>
          </div>
          <a
            href="https://wa.me/50660058595"
            target="_blank"
            rel="noreferrer"
            class="inline-flex w-full items-center justify-center gap-2 rounded-xl border border-cyan-300/20 bg-gradient-to-r from-[#f4f8fb] via-[#d9ecf8] to-[#bfe2f4] px-3 py-2 text-xs font-medium text-[#081018] shadow-[0_10px_24px_rgba(120,187,224,0.22)] transition duration-300 hover:translate-y-[-1px] sm:w-auto"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M19.05 4.91A9.82 9.82 0 0 0 12.03 2C6.62 2 2.2 6.4 2.2 11.82c0 1.73.45 3.42 1.3 4.9L2 22l5.44-1.42a9.82 9.82 0 0 0 4.58 1.16h.01c5.41 0 9.82-4.4 9.82-9.82A9.75 9.75 0 0 0 19.05 4.91Zm-7.02 15.18h-.01a8.1 8.1 0 0 1-4.12-1.12l-.3-.18-3.23.84.86-3.15-.2-.32a8.14 8.14 0 0 1-1.25-4.33c0-4.49 3.67-8.15 8.17-8.15 2.18 0 4.22.84 5.76 2.39a8.08 8.08 0 0 1 2.38 5.77c0 4.49-3.67 8.15-8.16 8.15Zm4.47-6.11c-.24-.12-1.42-.7-1.64-.78-.22-.08-.38-.12-.54.12-.16.23-.62.78-.76.94-.14.16-.28.18-.52.06-.24-.12-1.03-.38-1.95-1.21-.72-.64-1.2-1.43-1.34-1.67-.14-.24-.02-.37.1-.49.11-.11.24-.28.36-.42.12-.14.16-.24.24-.4.08-.16.04-.31-.02-.43-.06-.12-.54-1.3-.74-1.78-.2-.48-.4-.41-.54-.42h-.46c-.16 0-.42.06-.64.31-.22.24-.84.82-.84 2 0 1.18.86 2.33.98 2.49.12.16 1.7 2.6 4.12 3.65.58.25 1.03.4 1.38.51.58.18 1.1.16 1.51.1.46-.07 1.42-.58 1.62-1.14.2-.56.2-1.04.14-1.14-.06-.1-.22-.16-.46-.28Z" />
            </svg>
            <span>Contactarme</span>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- RIGHT CARD -->
  <div class="hidden">
    
    <!-- glow -->
    <div class="absolute inset-0 rounded-[2rem] bg-gradient-to-br from-cyan-500/20 via-transparent to-violet-500/20 blur-2xl"></div>

    <div class="relative rounded-[2rem] border border-white/10 bg-white/5 p-6 backdrop-blur-xl">
      
      <div class="space-y-5">

        <div class="flex items-center justify-between">
          <span class="text-sm text-white/50">Current Role</span>
          <span class="rounded-full border border-emerald-400/20 bg-emerald-400/10 px-3 py-1 text-xs text-emerald-300">
            Active
          </span>
        </div>

        <div>
          <h2 class="text-2xl font-semibold">
            Web Developer — Design Soft
          </h2>

          <p class="mt-2 text-white/65">
            Working on commercial websites, UI/UX improvements, SEO strategies and modern digital solutions.
          </p>
        </div>

        <div class="grid gap-3 sm:grid-cols-2">
          
          <div class="rounded-2xl border border-white/10 bg-black/20 p-4">
            <p class="text-sm text-white/45">Project</p>
            <p class="mt-1 text-lg font-medium">Taller Alpha</p>
          </div>

          <div class="rounded-2xl border border-white/10 bg-black/20 p-4">
            <p class="text-sm text-white/45">Project</p>
            <p class="mt-1 text-lg font-medium">POSMovi</p>
          </div>

          <div class="rounded-2xl border border-white/10 bg-black/20 p-4">
            <p class="text-sm text-white/45">Project</p>
            <p class="mt-1 text-lg font-medium">POS Restaurantes</p>
          </div>

          <div class="rounded-2xl border border-white/10 bg-black/20 p-4">
            <p class="text-sm text-white/45">Project</p>
            <p class="mt-1 text-lg font-medium">Taller de Motos</p>
          </div>

        </div>

      </div>
    </div>
  </div>

</section>

<script>
  import "../../scripts/hero-animation";
</script>
</div>
