        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" aria-hidden="true">
          <path d="M5 12h14" stroke-linecap="round" />
          <path d="m13 6 6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <span>Ver perfil</span>
      </a>

      <a
        href="https://wa.me/50660058595"
        target="_blank"
        rel="noreferrer"
        class="inline-flex items-center gap-2.5 rounded-2xl border border-cyan-200/24 bg-gradient-to-r from-[#2a556e]/92 via-[#33708f]/88 to-[#4b98b9]/84 px-[1.125rem] py-3 font-medium text-white shadow-[0_14px_36px_rgba(26,68,94,0.24)] backdrop-blur-xl transition duration-300 hover:translate-y-[-2px] hover:border-cyan-100/40 hover:shadow-[0_18px_48px_rgba(40,92,122,0.32)]"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M19.05 4.91A9.82 9.82 0 0 0 12.03 2C6.62 2 2.2 6.4 2.2 11.82c0 1.73.45 3.42 1.3 4.9L2 22l5.44-1.42a9.82 9.82 0 0 0 4.58 1.16h.01c5.41 0 9.82-4.4 9.82-9.82A9.75 9.75 0 0 0 19.05 4.91Zm-7.02 15.18h-.01a8.1 8.1 0 0 1-4.12-1.12l-.3-.18-3.23.84.86-3.15-.2-.32a8.14 8.14 0 0 1-1.25-4.33c0-4.49 3.67-8.15 8.17-8.15 2.18 0 4.22.84 5.76 2.39a8.08 8.08 0 0 1 2.38 5.77c0 4.49-3.67 8.15-8.16 8.15Zm4.47-6.11c-.24-.12-1.42-.7-1.64-.78-.22-.08-.38-.12-.54.12-.16.23-.62.78-.76.94-.14.16-.28.18-.52.06-.24-.12-1.03-.38-1.95-1.21-.72-.64-1.2-1.43-1.34-1.67-.14-.24-.02-.37.1-.49.11-.11.24-.28.36-.42.12-.14.16-.24.24-.4.08-.16.04-.31-.02-.43-.06-.12-.54-1.3-.74-1.78-.2-.48-.4-.41-.54-.42h-.46c-.16 0-.42.06-.64.31-.22.24-.84.82-.84 2 0 1.18.86 2.33.98 2.49.12.16 1.7 2.6 4.12 3.65.58.25 1.03.4 1.38.51.58.18 1.1.16 1.51.1.46-.07 1.42-.58 1.62-1.14.2-.56.2-1.04.14-1.14-.06-.1-.22-.16-.46-.28Z" />
        </svg>
        <span>WhatsApp</span>
      </a>
    </div>

    <div
      data-hero-tech
      class="relative w-full max-w-[36rem] overflow-hidden rounded-[1.75rem] border border-white/10 bg-[linear-gradient(180deg,rgba(255,255,255,0.05),rgba(255,255,255,0.02))] px-4 py-4 shadow-[0_20px_50px_rgba(0,0,0,0.18)] backdrop-blur-xl sm:px-5"
    >
      <div class="relative z-10 mb-4 space-y-2" data-tech-text-block>
        <div class="space-y-2">
          <p class="text-xs uppercase tracking-[0.24em] text-cyan-100/42">
            Desarrollo web
          </p>
          <p data-tech-text-line class="max-w-2xl text-sm leading-7 text-white/64 sm:text-[0.95rem]">
            Desarrollo soluciones web modernas con interfaces cuidadas, alto rendimiento y una implementación técnica sólida de principio a fin. Busco que cada proyecto mantenga equilibrio entre diseño, velocidad, usabilidad y calidad.
          </p>
          <p data-tech-text-line class="max-w-2xl text-sm leading-7 text-white/48 sm:text-[0.92rem]">
            Mi trabajo abarca experiencias frontend, integración de lógica backend cuando hace falta, buenas prácticas, SEO técnico y optimización para construir proyectos web completos, eficientes y bien estructurados.
          </p>
        </div>
      </div>

      <div
        class="relative max-w-[33rem] overflow-hidden [mask-image:linear-gradient(to_right,transparent,black_10%,black_90%,transparent)] [mask-repeat:no-repeat] [mask-size:100%_100%] [-webkit-mask-image:linear-gradient(to_right,transparent,black_10%,black_90%,transparent)] [-webkit-mask-repeat:no-repeat] [-webkit-mask-size:100%_100%]"
        data-tech-marquee
      >
        <div
          data-tech-marquee-track
          class="flex w-max items-center py-2"
        >
          <div data-tech-marquee-group class="flex items-center gap-4 sm:gap-5">
            {stackIcons.map((item) => (
              <div
                data-tech-icon-slot
                class="flex h-12 w-12 shrink-0 items-center justify-center sm:h-14 sm:w-14"
                tabindex="0"
              >
                <img
                  data-tech-icon
                  src={item.icon}
                  alt={item.name}
                  title={item.name}
                  loading="lazy"
                  class="h-7 w-auto max-w-[2.35rem] shrink-0 object-contain opacity-82 transition duration-300 hover:opacity-100 sm:h-8 sm:max-w-[2.7rem]"
                />
              </div>
            ))}
          </div>

          <div data-tech-marquee-group aria-hidden="true" class="flex items-center gap-4 sm:gap-5">
            {stackIcons.map((item) => (
              <div data-tech-icon-slot class="flex h-12 w-12 shrink-0 items-center justify-center sm:h-14 sm:w-14">
                <img
                  data-tech-icon
                  src={item.icon}
                  alt=""
                  loading="lazy"
                  class="h-7 w-auto max-w-[2.35rem] shrink-0 object-contain opacity-82 sm:h-8 sm:max-w-[2.7rem]"
                />
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>

  <div
    data-hero-media
    class="relative mx-auto mt-1 w-full max-w-[23rem] justify-self-center lg:mt-0 lg:max-w-[27.5rem] lg:justify-self-end xl:max-w-[29rem] 2xl:max-w-[31rem]"
  >
    <div
      data-hero-media-card
      style="--spotlight-x:50%; --spotlight-y:50%;"
      class="relative flex min-h-[35rem] overflow-hidden rounded-[2rem] border border-white/10 bg-white/5 p-3 shadow-[0_24px_80px_rgba(0,0,0,0.35)] backdrop-blur-xl lg:min-h-[40rem] xl:min-h-[42rem]"
    >
      <div
        data-hero-spotlight
        class="pointer-events-none absolute inset-0 opacity-0"
        style="background: radial-gradient(220px circle at var(--spotlight-x) var(--spotlight-y), rgba(255,255,255,0.22), rgba(140,216,255,0.1) 26%, transparent 62%);"
      ></div>
      <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_28%_18%,rgba(255,255,255,0.28),rgba(255,255,255,0.08)_22%,transparent_48%)] mix-blend-screen"></div>
      <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/12 via-transparent to-white/8"></div>
      <img
        src={profileImage.src}
        width={profileImage.width}
        height={profileImage.height}
        alt="Foto de Giancarlo Arias"
        class="h-full min-h-[31rem] w-full flex-1 rounded-[1.35rem] object-cover object-center lg:min-h-[37rem] xl:min-h-[39rem]"
        loading="eager"
      />
      <div class="absolute inset-x-3 bottom-3 z-10 rounded-[1.2rem] border border-white/10 bg-black/30 p-3 backdrop-blur-xl">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <p class="text-sm font-medium text-white">@giancarloarias96</p>
            <div class="mt-1 inline-flex items-center gap-2 text-xs text-white/70">
              <span class="h-2 w-2 rounded-full bg-emerald-400"></span>
              <span>Online</span>
            </div>
          </div>
          <a
            href="https://wa.me/50660058595"
            target="_blank"
            rel="noreferrer"
            class="inline-flex w-full items-center justify-center gap-2 rounded-xl border border-cyan-300/20 bg-gradient-to-r from-[#f4f8fb] via-[#d9ecf8] to-[#bfe2f4] px-3 py-2 text-xs font-medium text-[#081018] shadow-[0_10px_24px_rgba(120,187,224,0.22)] transition duration-300 hover:translate-y-[-1px] sm:w-auto"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M19.05 4.91A9.82 9.82 0 0 0 12.03 2C6.62 2 2.2 6.4 2.2 11.82c0 1.73.45 3.42 1.3 4.9L2 22l5.44-1.42a9.82 9.82 0 0 0 4.58 1.16h.01c5.41 0 9.82-4.4 9.82-9.82A9.75 9.75 0 0 0 19.05 4.91Zm-7.02 15.18h-.01a8.1 8.1 0 0 1-4.12-1.12l-.3-.18-3.23.84.86-3.15-.2-.32a8.14 8.14 0 0 1-1.25-4.33c0-4.49 3.67-8.15 8.17-8.15 2.18 0 4.22.84 5.76 2.39a8.08 8.08 0 0 1 2.38 5.77c0 4.49-3.67 8.15-8.16 8.15Zm4.47-6.11c-.24-.12-1.42-.7-1.64-.78-.22-.08-.38-.12-.54.12-.16.23-.62.78-.76.94-.14.16-.28.18-.52.06-.24-.12-1.03-.38-1.95-1.21-.72-.64-1.2-1.43-1.34-1.67-.14-.24-.02-.37.1-.49.11-.11.24-.28.36-.42.12-.14.16-.24.24-.4.08-.16.04-.31-.02-.43-.06-.12-.54-1.3-.74-1.78-.2-.48-.4-.41-.54-.42h-.46c-.16 0-.42.06-.64.31-.22.24-.84.82-.84 2 0 1.18.86 2.33.98 2.49.12.16 1.7 2.6 4.12 3.65.58.25 1.03.4 1.38.51.58.18 1.1.16 1.51.1.46-.07 1.42-.58 1.62-1.14.2-.56.2-1.04.14-1.14-.06-.1-.22-.16-.46-.28Z" />
            </svg>
            <span>Contactarme</span>
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="hidden">
    <div class="absolute inset-0 rounded-[2rem] bg-gradient-to-br from-cyan-500/20 via-transparent to-violet-500/20 blur-2xl"></div>

    <div class="relative rounded-[2rem] border border-white/10 bg-white/5 p-6 backdrop-blur-xl">
      
      <div class="space-y-5">

        <div class="flex items-center justify-between">
          <span class="text-sm text-white/50">Current Role</span>
          <span class="rounded-full border border-emerald-400/20 bg-emerald-400/10 px-3 py-1 text-xs text-emerald-300">
            Active
          </span>
        </div>

        <div>
          <h2 class="text-2xl font-semibold">
            Web Developer - Design Soft
          </h2>

          <p class="mt-2 text-white/65">
            Working on commercial websites, UI/UX improvements, SEO strategies and modern digital solutions.
          </p>
        </div>

        <div class="grid gap-3 sm:grid-cols-2">
          
          <div class="rounded-2xl border border-white/10 bg-black/20 p-4">
            <p class="text-sm text-white/45">Project</p>
            <p class="mt-1 text-lg font-medium">Taller Alpha</p>
          </div>

          <div class="rounded-2xl border border-white/10 bg-black/20 p-4">
            <p class="text-sm text-white/45">Project</p>
            <p class="mt-1 text-lg font-medium">POSMovi</p>
          </div>

          <div class="rounded-2xl border border-white/10 bg-black/20 p-4">
            <p class="text-sm text-white/45">Project</p>
            <p class="mt-1 text-lg font-medium">POS Restaurantes</p>
          </div>

          <div class="rounded-2xl border border-white/10 bg-black/20 p-4">
            <p class="text-sm text-white/45">Project</p>
            <p class="mt-1 text-lg font-medium">Taller de Motos</p>
          </div>

        </div>

      </div>
    </div>
  </div>

</section>

<script>
  import "../../utils/hero-animation";
  import "../../utils/hero-tech-marquee";

  const initTechWordHover = () => {
    document.querySelectorAll("[data-tech-text-line]").forEach((line) => {
      if (!(line instanceof HTMLElement) || line.dataset.splitReady === "true") return;

      const text = line.textContent?.trim();
      if (!text) return;

      line.dataset.splitReady = "true";
      line.setAttribute("aria-label", text);
      line.textContent = "";

      text.split(/\s+/).forEach((word, wordIndex, words) => {
        const wordSpan = document.createElement("span");
        wordSpan.dataset.techWord = "true";
        wordSpan.tabIndex = 0;
        wordSpan.style.display = "inline-flex";
        wordSpan.style.whiteSpace = "nowrap";
        wordSpan.style.verticalAlign = "baseline";
        wordSpan.style.cursor = "default";

        if (wordIndex < words.length - 1) {
          wordSpan.style.marginRight = "0.34em";
        }

        Array.from(word).forEach((letter, letterIndex) => {
          const letterSpan = document.createElement("span");
          letterSpan.dataset.techChar = "true";
          letterSpan.style.setProperty("--char-index", `${letterIndex}`);
          letterSpan.style.display = "inline-block";
          letterSpan.style.transform = "translate3d(0,0,0)";
          letterSpan.textContent = letter;
          wordSpan.appendChild(letterSpan);
        });

        let resetTimer = 0;
        const totalDuration = 1320 + Math.max(0, word.length - 1) * 48;

        const play = () => {
          window.clearTimeout(resetTimer);
          wordSpan.classList.remove("is-vaporizing");
          void wordSpan.offsetWidth;
          wordSpan.classList.add("is-vaporizing");
          resetTimer = window.setTimeout(() => {
            wordSpan.classList.remove("is-vaporizing");
          }, totalDuration);
        };

        wordSpan.addEventListener("pointerenter", play);
        wordSpan.addEventListener("focusin", play);
        line.appendChild(wordSpan);
      });
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initTechWordHover, { once: true });
  } else {
    initTechWordHover();
  }

  document.addEventListener("astro:page-load", initTechWordHover);
</script>

<style>
  [data-tech-word].is-vaporizing [data-tech-char] {
    animation: tech-word-vapor 1.32s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: calc(var(--char-index) * 48ms);
  }

  @keyframes tech-word-vapor {
    0% {
      transform: translate3d(0, 0, 0) scale(1);
      opacity: 1;
      filter: blur(0);
    }

    30% {
      transform: translate3d(0, -8px, 0) scale(1.02);
      opacity: 0;
      filter: blur(6px);
    }

    31% {
      transform: translate3d(0, 14px, 0) scale(0.97);
      opacity: 0;
      filter: blur(10px);
    }

    100% {
      transform: translate3d(0, 0, 0) scale(1);
      opacity: 1;
      filter: blur(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    [data-tech-word].is-vaporizing [data-tech-char] {
      animation: none;
    }
  }
</style>
</div>
