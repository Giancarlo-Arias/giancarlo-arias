---
import astroIcon from "@icons/astro.svg?url";
import gsapIcon from "@icons/gsap.svg?url";
import htmlIcon from "@icons/html.svg?url";
import jsIcon from "@icons/js.svg?url";
import nextjsIcon from "@icons/nextjs.svg?url";
import profileImage from "../../assets/images/profile/giancarlo.jpeg";
import reactIcon from "@icons/react.svg?url";
import seoIcon from "@icons/seo.svg?url";
import tailwindIcon from "@icons/tailwind.svg?url";
import tsIcon from "@icons/ts.svg?url";
import wordpressIcon from "@icons/wordpress.svg?url";

const stackIcons = [
  { name: "Astro", icon: astroIcon },
  { name: "Tailwind CSS", icon: tailwindIcon },
  { name: "JavaScript", icon: jsIcon },
  { name: "TypeScript", icon: tsIcon },
  { name: "React", icon: reactIcon },
  { name: "Next.js", icon: nextjsIcon },
  { name: "WordPress", icon: wordpressIcon },
  { name: "HTML", icon: htmlIcon },
  { name: "GSAP", icon: gsapIcon },
  { name: "SEO", icon: seoIcon },
];
---

<div data-hero-root>
<div
  data-hero-loader
  class="fixed inset-0 z-50 flex min-h-screen items-center justify-center overflow-hidden bg-[#0b0d12]"
>
  <div class="absolute inset-0">
    <div
      data-loader-line
      class="absolute left-1/2 top-0 h-full w-[2px] -translate-x-1/2 bg-gradient-to-b from-transparent via-white/70 to-transparent"
    ></div>
    <div class="absolute left-[-8%] top-[-8%] h-[24rem] w-[24rem] rounded-full bg-cyan-500/12 blur-3xl"></div>
    <div class="absolute right-[-10%] bottom-[-12%] h-[28rem] w-[28rem] rounded-full bg-sky-500/10 blur-3xl"></div>
  </div>

  <div
    class="relative grid w-full max-w-[88rem] grid-cols-[1fr_auto_1fr] items-center px-6 text-[clamp(2.4rem,8vw,7rem)] font-semibold tracking-tight text-white"
  >
    <span data-loader-word="left" class="justify-self-end pr-5 text-right sm:pr-8">Giancarlo</span>
    <span class="w-[2px]"></span>
    <span data-loader-word="right" class="justify-self-start pl-5 text-left sm:pl-8">Arias</span>
  </div>
</div>

<section
  data-hero
  class="mx-auto grid w-full max-w-7xl items-start gap-6 px-6 pt-14 pb-2 lg:grid-cols-[1.05fr_0.95fr] lg:gap-10 lg:pt-[4.5rem] lg:pb-4 2xl:max-w-[110rem] 2xl:px-10"
>
  <div class="space-y-6 pt-2 lg:space-y-7 lg:pt-2" data-hero-copy>
